# Copy to .env and customise.
# All variables are OPTIONAL — herm runs without any of them.

# Where to find hermes-agent source tree (gateway + hermes_cli).
# Default search order: ~/.hermes/hermes-agent, ~/Dev/hermes-agent.
# HERMES_AGENT_ROOT=/path/to/hermes-agent

# Python interpreter for the gateway subprocess.
# Default: $VIRTUAL_ENV/bin/python, then <root>/venv/bin/python, then python3.
# HERMES_PYTHON=/usr/bin/python3

# Override ~/.hermes for a portable / per-profile setup.
# HERMES_HOME=/path/to/alt-hermes-home

# Herm's own prefs file (defaults to ~/.config/herm/tui.json).
# HERM_CONFIG_DIR=~/.config/herm

# Colon-separated .eikon avatar search paths.
# Default: ~/.hermes/eikons, ~/Dev/eikon/avatars.
# HERM_EIKON_DIRS=/path/one:/path/two

# Enables the CONTROL HTTP server on localhost:7777 (headless testing).
# CONTROL=1

# Enables perf logging.
# PERF=1        # periodic memory + render stats
# PERF=verbose  # per-frame stats
