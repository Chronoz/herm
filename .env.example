# Copy to .env and customise. All variables are OPTIONAL —
# herm runs without any of them.

# Relocate the Hermes data dir (profiles, sessions, eikons, etc.).
# Default: ~/.hermes. Set only if yours lives elsewhere.
# HERMES_HOME=/path/to/alt-hermes-home

# ── Rarely needed ──────────────────────────────────────────────────

# Override the hermes-agent source tree. Default is
# $HERMES_HOME/hermes-agent — where brew and `hermes update` put it.
# Set this for dev clones or non-standard layouts.
# HERMES_AGENT_ROOT=/path/to/hermes-agent

# Python interpreter for the gateway subprocess. Default tries
# $VIRTUAL_ENV → <root>/venv → <root>/.venv → python3.
# HERMES_PYTHON=/usr/bin/python3

# Relocate herm's own prefs + input history.
# Default: $HERMES_HOME/herm.
# HERM_CONFIG_DIR=/path/to/alt-herm-config

# ── Debug / testing ────────────────────────────────────────────────

# CONTROL HTTP server on localhost:7777 (headless testing).
# CONTROL=1
# CONTROL_PORT=7777

# Perf logging.
# PERF=1        # periodic memory + render stats
# PERF=verbose  # per-frame stats
