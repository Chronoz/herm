# Copy to .env and customise.
# All variables are OPTIONAL — herm runs without any of them if you
# have a normal Hermes install (brew or `hermes update`).

# ── The two you might actually need ────────────────────────────────

# Path to the hermes-agent source tree (gateway + hermes_cli).
# Default: ~/.hermes/hermes-agent — this is where `hermes update` and
# the brew formula install it, so stock installs just work.
# Set this only for dev clones or non-standard layouts.
# HERMES_AGENT_ROOT=/path/to/hermes-agent

# Python interpreter for the gateway subprocess.
# Default: $VIRTUAL_ENV/bin/python, then <root>/venv/bin/python,
# then <root>/.venv/bin/python, then python3.
# Set this only if the fallback picks the wrong env.
# HERMES_PYTHON=/usr/bin/python3

# ── Standard unix ──────────────────────────────────────────────────

# Used by <leader>e (open composer in external editor).
# Not herm-specific; most shells already export one of these.
# EDITOR=vim
# VISUAL=code

# ── Advanced / rarely needed ───────────────────────────────────────

# Relocate the entire Hermes data dir (profiles, sessions, eikons, etc.).
# HERMES_HOME=/path/to/alt-hermes-home

# Relocate herm's own prefs + input history.
# Default: $HERMES_HOME/herm (typically ~/.hermes/herm).
# HERM_CONFIG_DIR=/path/to/alt-herm-config

# Gateway cwd override. Default: HERMES_AGENT_ROOT.
# HERMES_CWD=/path/to/project

# ── Debug / testing ────────────────────────────────────────────────

# Enables the CONTROL HTTP server on localhost:7777 (headless testing).
# CONTROL=1
# CONTROL_PORT=7777

# Enables perf logging.
# PERF=1        # periodic memory + render stats
# PERF=verbose  # per-frame stats
