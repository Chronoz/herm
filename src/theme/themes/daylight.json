      "light": "daylightOkLight"
    },
    "diffRemoved": {
      "dark": "daylightErrorDark",
      "light": "daylightErrorLight"
    },
    "diffContext": {
      "dark": "daylightMutedDark",
      "light": "daylightMutedLight"
    },
    "diffHunkHeader": {
      "dark": "daylightMutedDark",
      "light": "daylightMutedLight"
